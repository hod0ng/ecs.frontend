{
    "family": "taskdef-front",
    "taskRoleArn": "arn:aws:iam::481665114569:role/task-executionRole",
    "executionRoleArn": "arn:aws:iam::481665114569:role/task-executionRole",
    "networkMode": "bridge",
    "containerDefinitions": [
        {
            "name": "frontend-con",
            "image": "<IMAGE1_NAME>",
            "cpu": 512,
            "memory": 922,
            "memoryReservation": 512,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 0,
                    "protocol": "tcp",
                    "name": "frontend-port",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/taskdef-front",
                    "awslogs-create-group": "true",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": ["EC2"],
    "cpu": "512",
    "memory": "1024"
}
